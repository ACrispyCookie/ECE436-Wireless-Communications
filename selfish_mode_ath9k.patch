@@ -17,6 +17,12 @@
 #include "hw.h"
 #include "hw-ops.h"
 #include <linux/export.h>
+#include <linux/moduleparam.h>
+
+bool selfish_mode = false;
+module_param(selfish_mode, bool, 0644);
+MODULE_PARM_DESC(selfish_mode,
+	"Disable CSMA/CA: CW=0, AIFS=1, ignore CCA (not yet)");
 
